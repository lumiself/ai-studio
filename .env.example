# ── Supabase ──────────────────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Replicate ────────────────────────────────────────────────────────────
# Found at https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_...

# Webhook signing secret — found in Replicate dashboard → Webhooks
# Used to verify that POST /api/webhook/replicate calls come from Replicate.
REPLICATE_WEBHOOK_SECRET=whsec_...

# ── Shared Hosting Storage ───────────────────────────────────────────────
# URL of the upload.php script on your shared hosting
STORAGE_UPLOAD_URL=https://yoursite.com/ai-uploads/upload.php

# Long random secret — must match AI_STUDIO_SECRET env var on shared hosting
STORAGE_SECRET_TOKEN=change-me-to-a-long-random-string

# Public base URL of the ai-uploads directory (with trailing slash)
STORAGE_BASE_URL=https://yoursite.com/ai-uploads/

# ── App URL ───────────────────────────────────────────────────────────────
# Used to build the Replicate webhook URL.
# On Vercel this is auto-set as VERCEL_URL; set NEXT_PUBLIC_APP_URL for
# production custom domains.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
